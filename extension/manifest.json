{
  "manifest_version": 3,
  "name": "Prism",
  "version": "1.0.0",
  "description": "Your tabs, refracted. New tab page that groups your open tabs by domain with a glassmorphism dashboard.",
  "permissions": ["tabs", "activeTab", "storage"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Prism",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
